# ─────────────────────────────────────────────────────────────
# LAN / Network Access Override
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and set your machine's LAN IP.
# Find your IP:
#   Windows  →  ipconfig  (look for "IPv4 Address")
#   macOS    →  ifconfig | grep "inet " | grep -v 127
#   Linux    →  hostname -I
#
# .env.local overrides .env — localhost still works on the dev machine
# because the backend is reachable via its LAN IP too.
# ─────────────────────────────────────────────────────────────

# Replace 192.168.x.x with your actual LAN IP (run `ipconfig`)
VITE_APP_WISE_TECH_BACKEND=http://192.168.x.x:9000
